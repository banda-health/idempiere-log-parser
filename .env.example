# Application information
CHOKIDAR_USEPOLLING=true
CONSIDER_EXISTING=false
CONSIDER_ARCHIVED=false

# iDempiere Information
IDEMPIERE_LOG_DIRECTORY=
IDEMPIERE_LOG_ARCHIVE_DIRECTORY=
IDEMPIERE_USER=
IDEMPIERE_HOST=
IDEMPIERE_DATABASE=
IDEMPIERE_PASSWORD=
IDEMPIERE_DB_PORT=

# Grafana Information
GRAFANA_TABLE=idempiere_log
GRAFANA_USER=
GRAFANA_HOST=
GRAFANA_DATABASE=grafana
GRAFANA_PASSWORD=
GRAFANA_DB_PORT=

# Clear variables JSON from GraphQL log records older than this many days (0 = disabled).
# Site activity logs (query_type = log) are kept unless they contain sensitive fields.
PII_VARIABLES_RETENTION_DAYS=90
